<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
	<Product Id="*" 
           Name="$(var.ComponentName)"
           Language="1033" 
           Version="$(var.ProductVersion)" 
           Manufacturer="Philips Healthcare"
           UpgradeCode="$(var.UpgradeCode)">
		<Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
		<MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
		<MediaTemplate EmbedCab="yes"/>
		<Property Id="INSTALLFOLDER">$(var.TargetFolder)</Property>
		<Feature Id="ProductFeature" Title="CT_3rdPartyApp" Level="1">
			<ComponentGroupRef Id="ProductComponents" />
		</Feature>
	</Product>

	<Fragment>
		<Directory Id="TARGETDIR" Name="SourceDir">
			<Directory Id="ProgramFilesFolder">
                <Directory Id="Philips" Name="Philips Healthcare">
                        <Directory Id="INSTALLFOLDER" Name="$(var.ComponentName)" />
                </Directory>
			</Directory>
		</Directory>
	</Fragment>

	<Fragment>
		<ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <ComponentGroupRef Id="DynamicFragment" />
		</ComponentGroup>
	</Fragment>
</Wix>